# Required settings
ANTHROPIC_API_KEY=your-api-key-here
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here
PUBMED_EMAIL=your.email@example.com

